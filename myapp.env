# ===============================
# SPRING BOOT DATABASE CONFIG
# ===============================
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/my_app_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# ===============================
# MYSQL CONTAINER CONFIG
# ===============================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=myapp_db
MYSQL_USER=spring_user
MYSQL_PASSWORD=spring_secret_password
